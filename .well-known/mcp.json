{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.kira-autonoma/agent-memory-mcp",
  "description": "Agent memory MCP server with provenance tracking, decay-weighted recall, and feedback loops.",
  "repository": {
    "url": "https://github.com/kira-autonoma/agent-memory-mcp",
    "source": "github"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@kiraautonoma/agent-memory-mcp",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MEMORY_DB_PATH",
          "description": "Path to SQLite database file (default: ~/.agent-memory/memory.db)"
        }
      ]
    }
  ]
}
